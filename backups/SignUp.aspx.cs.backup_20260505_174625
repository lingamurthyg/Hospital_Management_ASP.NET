namespace DBProject
{
    public partial class SignUp : System.Web.UI.Page
    {
        // Cloud-ready: Error message property for client-side display
        protected string ErrorMessage { get; set; }
        protected string ErrorClass { get; set; }

        protected void Page_Load(object sender, EventArgs e)
        {
            // Cloud-ready: Initialize session with null check
            if (Session["idoriginal"] == null)
            {
                Session["idoriginal"] = "";
            }

            ErrorMessage = "";
            ErrorClass = "hidden";
        }

        //-----------------------Function1--------------------------//
        protected void loginV(object sender, EventArgs e)
        {
            string email = loginEmail.Text;
            string password = loginPassword.Text;

            myDAL objmyDAl = new myDAL();

            int status = 0;
            int type = 0;
            int id = 0;

            status = objmyDAl.validateLogin(email, password, ref type, ref id);

            if (status == 0)
            {
                Session["idoriginal"] = id;

                if (type == 1)
                {
                    Response.BufferOutput = true;
                    Response.Redirect("~/Patient/PatientHome.aspx", false);
                    Context.ApplicationInstance.CompleteRequest();
                    return;
                }

                else if (type == 2)
                {
                    Response.BufferOutput = true;
                    Response.Redirect("~/Doctor/DoctorHome.aspx", false);
                    Context.ApplicationInstance.CompleteRequest();
                    return;
                }

                else if (type == 3)
                {
                    Response.BufferOutput = true;
                    Response.Redirect("~/Admin/AdminHome.aspx", false);
                    Context.ApplicationInstance.CompleteRequest();
                    return;
                }
            }

            // Cloud-ready: Removed XSS vulnerability - use server-side Label controls instead
            // Set error messages in properties to be displayed in markup
            else if (status == 1)
            {
                ErrorMessage = "Email not found. Please try again.";
                ErrorClass = "alert alert-danger";
                // Cloud-ready: Log to console for CloudWatch
                Console.WriteLine($"[WARN] Login failed - email not found: {email}");
            }

            else if (status == 2)
            {
                ErrorMessage = "Incorrect password. Please try again.";
                ErrorClass = "alert alert-warning";
                Console.WriteLine($"[WARN] Login failed - incorrect password for: {email}");
            }

            else if (status == -1)
            {
                ErrorMessage = "An error occurred. Please try again later.";
                ErrorClass = "alert alert-danger";
                Console.WriteLine($"[ERROR] Login error for user: {email}");
            }
        }




        //-----------------------Function2--------------------------//
        protected void signupV(object sender, EventArgs e)
        {
            string Name = sName.Text;
            string BirthDate = sBirthDate.Text;
            string Email = sEmail.Text;
            string Password = sPassword.Text;
            string PhoneNo = Phone.Text;
            string Addr = Address.Text;

            string gender = Request.Form["Gender"].ToString();
           


            myDAL objmyDAl = new myDAL();

            int id = 0;

            int status = objmyDAl.validateUser(Name, BirthDate, Email, Password, PhoneNo, gender, Addr, ref id);


            //status == 0 failure
            // Cloud-ready: Removed XSS vulnerability - use server-side Label controls
            if (status == 0)
            {
                ErrorMessage = "Email already exists. Please choose a different email address.";
                ErrorClass = "alert alert-warning";
                Console.WriteLine($"[WARN] Signup failed - duplicate email: {Email}");
            }

            else if (status == 1)
            {
                Session["idoriginal"] = id;

                // Cloud-ready: Log successful registration
                Console.WriteLine($"[INFO] User registered successfully: {Email}");

                Response.BufferOutput = true;
                Response.Redirect("~/Patient/PatientHome.aspx", false);
                Context.ApplicationInstance.CompleteRequest();
            }

            else if (status == -1)
            {
                ErrorMessage = "An error occurred during registration. Please try again later.";
                ErrorClass = "alert alert-danger";
                Console.WriteLine($"[ERROR] Signup error for user: {Email}");
            }
           
        }

