using System;
using System.Collections.Generic;
using System.Linq;
using System.Web;
using System.Web.UI;
using System.Web.UI.WebControls;
using DBProject.DAL;
using System.Data;

namespace doctor
{
    public partial class Historyupdate : System.Web.UI.Page
    {
        // Cloud-ready: Error message properties for safe display
        protected string ErrorMessage { get; set; }
        protected string SuccessMessage { get; set; }

        protected void Page_Load(object sender, EventArgs e)
        {
            // Cloud-ready: Validate session state on page load
            if (Session["idoriginal"] == null || Session["appointid"] == null)
            {
                Console.WriteLine("[WARN] Session expired or invalid - redirecting to login");
                Response.Redirect("~/SignUp.aspx", false);
                Context.ApplicationInstance.CompleteRequest();
                return;
            }

            ErrorMessage = "";
            SuccessMessage = "";
        }

        public void saveindatabase(object sender, EventArgs e)
        {
            myDAL objmyDAL = new myDAL();
            int found;

            // Cloud-ready: Safe type casting with null checks and validation
            if (Session["idoriginal"] == null || Session["appointid"] == null)
            {
                ErrorMessage = "Session expired. Please login again.";
                Console.WriteLine("[ERROR] Session data missing in saveindatabase");
                Response.Redirect("~/SignUp.aspx", false);
                Context.ApplicationInstance.CompleteRequest();
                return;
            }

            // Cloud-ready: Safe casting with TryParse pattern
            int did;
            int appid;

            if (!int.TryParse(Session["idoriginal"]?.ToString(), out did))
            {
                ErrorMessage = "Invalid session data. Please login again.";
                Console.WriteLine("[ERROR] Invalid doctor ID in session");
                return;
            }

            if (!int.TryParse(Session["appointid"]?.ToString(), out appid))
            {
                ErrorMessage = "Invalid appointment data. Please try again.";
                Console.WriteLine("[ERROR] Invalid appointment ID in session");
                return;
            }

            string disease= Disease.Text;
            string progres = progress.Text;
            string prescrip = Prescription.Text;

            found = objmyDAL.update_prescription_DAL(did,appid,disease,progres,prescrip);

            // Cloud-ready: Removed XSS vulnerability - use server-side controls
            if (found != 1)
            {
                ErrorMessage = "An error occurred while updating information.";
                Console.WriteLine($"[ERROR] Failed to update prescription for appointment {appid}");
            }
            else
            {
                SuccessMessage = "Information successfully updated.";
                Console.WriteLine($"[INFO] Prescription updated successfully for appointment {appid}");
            }
        }


        public void generate_bill(object sender, EventArgs e)
        {
            Response.Redirect("bill.aspx", false);
            Context.ApplicationInstance.CompleteRequest();
        }
    }
}