@page
@model ClinicManagement.Web.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2>Admin Dashboard</h2>

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">Total Patients</h5>
                <p class="card-text display-4">@Model.PatientCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">Total Doctors</h5>
                <p class="card-text display-4">@Model.DoctorCount</p>
                <a asp-page="/Admin/RegisterDoctor" class="btn btn-primary btn-sm">Add Doctor</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">Total Appointments</h5>
                <p class="card-text display-4">@Model.AppointmentCount</p>
            </div>
        </div>
    </div>
</div>
