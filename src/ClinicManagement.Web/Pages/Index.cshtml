@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="text-center">
    <h1 class="display-4">Welcome to Clinic Management System</h1>
    <p class="lead">Manage patients, doctors, appointments, and medical records efficiently.</p>
</div>

<div class="row mt-5">
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">Patients</h5>
                <p class="card-text">Manage patient information and medical history.</p>
                <a href="/Patients/Index" class="btn btn-primary">View Patients</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">Doctors</h5>
                <p class="card-text">Manage doctor profiles and specializations.</p>
                <a href="/Doctors/Index" class="btn btn-primary">View Doctors</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">Appointments</h5>
                <p class="card-text">Schedule and manage patient appointments.</p>
                <a href="/Appointments/Index" class="btn btn-primary">View Appointments</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">Departments</h5>
                <p class="card-text">Manage clinic departments.</p>
                <a href="/Departments/Index" class="btn btn-primary">View Departments</a>
            </div>
        </div>
    </div>
</div>
