@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="text-center">
    <h1 class="display-4">Welcome to Clinic Management System</h1>
    <p>A modern healthcare management solution built with .NET 8</p>

    <div class="row mt-5">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Patients</h5>
                    <p class="card-text">Manage patient records and appointments</p>
                    <a asp-page="/Patients/Index" class="btn btn-primary">View Patients</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Doctors</h5>
                    <p class="card-text">Manage doctor profiles and schedules</p>
                    <a asp-page="/Doctors/Index" class="btn btn-primary">View Doctors</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Appointments</h5>
                    <p class="card-text">Schedule and manage appointments</p>
                    <a asp-page="/Appointments/Index" class="btn btn-primary">View Appointments</a>
                </div>
            </div>
        </div>
    </div>
</div>
