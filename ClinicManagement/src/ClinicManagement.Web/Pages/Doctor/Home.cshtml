@page
@model ClinicManagement.Web.Pages.Doctor.HomeModel
@{
    ViewData["Title"] = "Doctor Home";
}

<div class="container mt-4">
    <h2>Welcome, Dr. @Model.DoctorName</h2>
    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Pending Appointments</h5>
                    <a asp-page="/Doctor/Appointments" class="btn btn-primary">View</a>
                </div>
            </div>
        </div>
    </div>
</div>
