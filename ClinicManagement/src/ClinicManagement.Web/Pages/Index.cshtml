@page
@model ClinicManagement.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Clinic Management System - Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="text-center">Clinic Management System</h3>
                </div>
                <div class="card-body">
                    <ul class="nav nav-tabs mb-3" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" data-bs-toggle="tab" href="#login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#signup">Sign Up</a>
                        </li>
                    </ul>

                    <div class="tab-content">
                        <div id="login" class="tab-pane fade show active">
                            <form method="post" asp-page-handler="Login">
                                <div class="mb-3">
                                    <label asp-for="LoginInput.Email" class="form-label">Email</label>
                                    <input asp-for="LoginInput.Email" class="form-control" type="email" required />
                                </div>
                                <div class="mb-3">
                                    <label asp-for="LoginInput.Password" class="form-label">Password</label>
                                    <input asp-for="LoginInput.Password" class="form-control" type="password" required />
                                </div>
                                <button type="submit" class="btn btn-primary w-100">Login</button>
                            </form>
                        </div>

                        <div id="signup" class="tab-pane fade">
                            <form method="post" asp-page-handler="Signup">
                                <div class="mb-3">
                                    <label asp-for="SignupInput.Name" class="form-label">Full Name</label>
                                    <input asp-for="SignupInput.Name" class="form-control" required />
                                </div>
                                <div class="mb-3">
                                    <label asp-for="SignupInput.Email" class="form-label">Email</label>
                                    <input asp-for="SignupInput.Email" class="form-control" type="email" required />
                                </div>
                                <div class="mb-3">
                                    <label asp-for="SignupInput.Password" class="form-label">Password</label>
                                    <input asp-for="SignupInput.Password" class="form-control" type="password" required />
                                </div>
                                <div class="mb-3">
                                    <label asp-for="SignupInput.PhoneNo" class="form-label">Phone Number</label>
                                    <input asp-for="SignupInput.PhoneNo" class="form-control" required />
                                </div>
                                <div class="mb-3">
                                    <label asp-for="SignupInput.BirthDate" class="form-label">Birth Date</label>
                                    <input asp-for="SignupInput.BirthDate" class="form-control" type="date" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Gender</label>
                                    <div>
                                        <div class="form-check form-check-inline">
                                            <input asp-for="SignupInput.Gender" class="form-check-input" type="radio" value="Male" id="male" />
                                            <label class="form-check-label" for="male">Male</label>
                                        </div>
                                        <div class="form-check form-check-inline">
                                            <input asp-for="SignupInput.Gender" class="form-check-input" type="radio" value="Female" id="female" />
                                            <label class="form-check-label" for="female">Female</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="SignupInput.Address" class="form-label">Address</label>
                                    <textarea asp-for="SignupInput.Address" class="form-control" rows="2"></textarea>
                                </div>
                                <button type="submit" class="btn btn-success w-100">Sign Up</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <script>
        alert('@Html.Raw(Model.Message)');
    </script>
}
